{
  "expo": {
    "name": "MyPortfolio",
    "slug": "MyPortfolio",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/MYP.png",
      "resizeMode": "contain",
      "backgroundColor": "#003366"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#003366",
          "image": "./assets/MYP.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikasi membutuhkan akses galeri untuk mengganti foto profil."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.mznf.myportfolio",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#003366"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "dd87b75e-5e2a-429d-871b-1a36df6aa644"
      }
    },
    "owner": "zakyxxxx"
  }
}
